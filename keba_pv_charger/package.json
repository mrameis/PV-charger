{
  "name": "keba-pv-charger",
  "version": "1.0.0",
  "description": "PV-Überschussladen für Keba KeContact P30c via Modbus TCP, mit Web-Dashboard",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "modbus-serial": "^8.0.19",
    "node-fetch": "^2.7.0",
    "ws": "^8.18.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/node-fetch": "^2.6.11",
    "@types/ws": "^8.5.12",
    "@types/xml2js": "^0.4.14",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
